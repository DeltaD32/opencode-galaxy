# JARVIS — HOME profile (fully local, no cloud). Copy to .env and pick ONE backend.
#   cp config/home.env.example .env   (then edit)
# In home mode, cloud providers/embeddings are refused in code and the egress
# allowlist drops every cloud host. Run `python -m jarvis.doctor` to verify.

JARVIS_PROFILE=home

# ── Pick ONE backend ────────────────────────────────────────────────────────
# Ollama (start `ollama serve`; `ollama pull qwen2.5-coder`):
JARVIS_LLM_PROVIDER=ollama
JARVIS_MODEL=qwen2.5-coder

# LM Studio (load a tool-capable model, start its local server on :1234):
# JARVIS_LLM_PROVIDER=lmstudio
# JARVIS_MODEL=qwen2.5-coder-7b-instruct

# ── Local everything else ───────────────────────────────────────────────────
# Embeddings: 'local' = fastembed bge-small (offline, real semantics);
#             'hash'  = zero-dependency offline fallback.
JARVIS_EMBED_ENGINE=local

JARVIS_DB_PATH=./.jarvis/state.db
JARVIS_MEMORY_PATH=./.jarvis/memory.db

# Do NOT set LLM_API_* or ANTHROPIC_API_KEY in home mode — the doctor flags them.
