# JARVIS — copy to .env and fill in (never commit .env). See JARVIS-BUILD-MANUAL Step 1.

# LLM backend. Run at home with a local model, or use the BMW gateway / Claude.
#   ollama    → local Ollama   (start `ollama serve`; set JARVIS_MODEL=llama3.1)
#   lmstudio  → local LM Studio (start its server on :1234)
#   bmw       → BMW gateway     (needs LLM_API_BEARER_TOKEN + LLM_API_KEY below)
#   anthropic → Claude public API (needs ANTHROPIC_API_KEY; JARVIS_MODEL=claude-sonnet-4-6)
JARVIS_LLM_PROVIDER=ollama
JARVIS_MODEL=llama3.1

# Only needed for JARVIS_LLM_PROVIDER=bmw:
LLM_API_BASE_URL=https://api.gcp.cloud.bmw/llmapi/v1
LLM_API_BEARER_TOKEN=        # OAuth2 token your gateway login provides
LLM_API_KEY=                 # BMW gateway key
# Only needed for JARVIS_LLM_PROVIDER=anthropic:
ANTHROPIC_API_KEY=

JARVIS_DB_PATH=./.jarvis/state.db

# Embeddings engine for memory: 'local' (fastembed bge-small, real semantics),
# 'hash' (offline, no deps — used by tests), or 'bmw' (gateway). Defaults to local.
JARVIS_EMBED_ENGINE=local
