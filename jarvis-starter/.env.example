# JARVIS — copy to .env and fill in (never commit .env). See JARVIS-BUILD-MANUAL Step 1.
LLM_API_BASE_URL=https://api.gcp.cloud.bmw/llmapi/v1
LLM_API_BEARER_TOKEN=        # OAuth2 token your gateway login provides
LLM_API_KEY=                 # BMW gateway key
JARVIS_MODEL=anthropic/claude-sonnet-4-6
JARVIS_DB_PATH=./.jarvis/state.db

# Embeddings engine for memory: 'local' (fastembed bge-small, real semantics),
# 'hash' (offline, no deps — used by tests), or 'bmw' (gateway). Defaults to local.
JARVIS_EMBED_ENGINE=local
